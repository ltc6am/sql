rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Phase 4: Validation Blueprint for UserProgress
    function isValidUserProgress(data) {
      return data.keys().hasAll(['lastLevel']) 
          && data.keys().size() == 1
          && data.lastLevel is int
          && data.lastLevel >= 0;
    }

    // Rules for Users collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) 
                           && isValidId(userId)
                           && isValidUserProgress(incoming());
    }

    // Allow the connection test document to be read (get only) if signed in
    // This supports the getDocFromServer check at boot time
    match /test/connection {
      allow get: if isSignedIn();
    }
  }
}
